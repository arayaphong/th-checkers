{
  "name": "th-checkers",
  "version": "1.0.0",
  "description": "Thai checkers game logic implemented in TypeScript.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arayaphong/th-checkers.git"
  },
  "bugs": {
    "url": "https://github.com/arayaphong/th-checkers/issues"
  },
  "homepage": "https://github.com/arayaphong/th-checkers#readme",
  "scripts": {
    "build": "tsc",
    "start": "node run.js",
    "demo": "npm run build && node dist/app/demo.js",
    "demo:branching-capture": "npm run build && node dist/app/demo1.js",
    "demo:loop-capture": "npm run build && node dist/app/demo2.js",
    "demo:loop-branching-capture1": "npm run build && node dist/app/demo31.js",
    "demo:loop-branching-capture2": "npm run build && node dist/app/demo32.js",
    "prepare": "npm run build",
    "test": "node --no-warnings --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:dom": "node --no-warnings --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand tests/html/game.test.ts",
    "test:e2e": "npm run build && playwright test",
    "lint": "eslint html/js html/game.js src tests",
    "test:all": "npm test -- --runInBand && npm run test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1"
  }
}
